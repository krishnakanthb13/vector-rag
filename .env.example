# === Vector Store ===
CHROMA_DIR=./chroma_db
COLLECTION_NAME=my_documents

# === Embedding Model (local, from sentence-transformers) ===
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Chat LLM (Gemini) ===
CHAT_MODEL=gemini-3.1-flash-lite
FALLBACK_MODEL=gemma-3-27b-it
GEMINI_API_KEY=your-gemini-api-key-here

# === Source Documents ===
SOURCE_DIR=./source_docs

# === Retrieval Settings ===
TOP_K=20
MIN_SIMILARITY=0.25

# === History ===
HISTORY_LOG=./scripts/history.md
